SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Lovable injects this on hosted preview/deploy — value is NOT shown in Secrets UI (rotate only).
LOVABLE_API_KEY=""

# Google AI Studio — supports new AQ.* auth keys and legacy AIza* keys
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Optional — bypasses RLS for admin server ops. Not required for local MVP dev.
SUPABASE_SERVICE_ROLE_KEY=""

# Telegram — subscription requests from pricing page
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
